{
    "name": "michaelyousrie/batframe-skeleton",
    "description": "A skeleton to bootstrap a new Batframe application with `composer create-project`.",
    "type": "project",
    "license": "MIT",
    "keywords": ["batframe", "skeleton", "starter", "template", "microframework"],
    "require": {
        "php": "^8.1",
        "michaelyousrie/batframe": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "serve": "@php batbelt serve"
    },
    "config": {
        "sort-packages": true
    }
}
